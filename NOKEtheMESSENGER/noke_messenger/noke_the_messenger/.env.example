# Twilio Credentials
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# SendGrid (for email) - https://sendgrid.com
# Twilio owns SendGrid so it works great together
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=yourname@yourdomain.com

# Your company name (appears in messages)
COMPANY_NAME=NOKE Smart Entry

# Path to your Excel contacts file
EXCEL_PATH=contacts.xlsx
