[Unit]
Description=Sound Parking (Node/Express)
After=network.target

[Service]
User=www-data
WorkingDirectory=/opt/soundcheck.tools/SoundParking/rock-nashville-parking
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
# Where the Node app reaches ADMIN to resolve who is logged in (for the logger).
Environment=ADMIN_URL=http://127.0.0.1:5000

[Install]
WantedBy=multi-user.target
